    "custom/recorder": {
		"format": "!пЂЅ",
		"return-type": "json",
		"interval": 3,
		"exec": "echo '{\"class\": \"recording\"}'",
		"exec-if": "pgrep wf-recorder",
        "tooltip": false,
        "on-click": "killall -s SIGINT wf-recorder"
	},
    "battery": {
        "format": "<span font='Font Awesome 5 Free 11'>{icon}</span> {capacity}%{time}",
        "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"],
        "format-time": " ({H}h{M}m)",
        "format-charging": "<span font='Font Awesome 5 Free'>пѓ§</span>  <span font='Font Awesome 5 Free 11'>{icon}</span>  {capacity}% - {time}",
        "format-full": "<span font='Font Awesome 5 Free'>пѓ§</span>  <span font='Font Awesome 5 Free 11'>{icon}</span>  Charged",
        "interval": 15,
        "states": {
            "warning": 25,
            "critical": 10
        },
        "tooltip": false
    },
    "network": {
        "format": "{icon}",
        "format-alt": "<span font='Font Awesome 5 Free 10'>п•‚пёЃ</span> пёЃ{ipaddr}/{cidr} {icon}",
        "format-alt-click": "click-left",
        "format-wifi": "<span font='Font Awesome 5 Free 10'>п‡«</span> {essid} ({signalStrength}%)",
        "format-ethernet": "<span font='Font Awesome 5 Free 10'>пћ–пёЃ</span> {ifname}",
        "format-disconnected": "вљ  Disconnected",
        "tooltip": false
    },
    "pulseaudio": {
        "format": "<span font='Font Awesome 5 Free 11'>{icon:2}</span>{volume}%",
        "format-alt": "<span font='Font Awesome 5 Free 11'>{icon:2}</span>{volume}%",
        "format-alt-click": "click-right",
        "format-muted": "<span font='Font Awesome 5 Free 11'>пљ©</span>",
        "format-icons": {
