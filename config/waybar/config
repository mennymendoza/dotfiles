            "default": ["пЂ¦", "пЂ§", "пЂ§", "пЂЁ"]
        },
        "scroll-step": 2,
        "on-click": "pavucontrol",
        "tooltip": false
    },
    "backlight": {
        "format": "{icon} {percent}%",
        "format-alt": "{icon}",
        "format-alt-click": "click-left",
        "format-icons": ["пѓ«", "пѓ«"],
        "on-scroll-up": "light -A 1",
